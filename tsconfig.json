{
    "compilerOptions": {
        "sourceMap": true,
        "target": "es6",
        "jsx": "react",
        "module": "node20",
        "moduleResolution": "node16",
        "experimentalDecorators": true,
        "declaration": false,
        "removeComments": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "build",
        "lib": ["es6", "es7", "dom"],
        "types": ["node"],
        "baseUrl": "src",
        "paths": {
            "app/*": ["./app/*"]
        }
    },
    "exclude": ["dist", "build", "node_modules"]
}
